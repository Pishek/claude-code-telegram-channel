 // Stores full permission details for "See more" expansion keyed by request_id.
 const pendingPermissions = new Map<string, { tool_name: string; description: string; input_preview: string }>()
 
+// Tracks the most recent unresolved permission so a bare "yes"/"no" reply
+// (e.g. dictated from an Apple Watch, where inline buttons aren't tappable)
+// can resolve it without needing the 5-char request_id. Cleared on resolve.
+let latestPermissionId: string | null = null
+
+// Compact one-glance preview of the tool input for the initial permission
+// message, so the user sees file_path/command without pressing "See more".
+function formatPermPreview(input_preview: string): string {
+  let s = input_preview
+  try {
+    const o = JSON.parse(input_preview)
+    if (o && typeof o === 'object') {
+      s = Object.entries(o)
+        .map(([k, v]) => `${k}: ${typeof v === 'string' ? v : JSON.stringify(v)}`)
+        .join('\n')
+    }
+  } catch {}
+  s = s.trim()
+  return s.length > 300 ? s.slice(0, 300) + '…' : s
+}
